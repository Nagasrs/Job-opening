import uuid
from typing import List, Dict, Optional, Any
from pydantic import BaseModel, Field
import pandas as pd
import re

# --- OpenEnv Typed Models ---

class Action(BaseModel):
    row_index: int
    column_name: str
    transformation: str = Field(..., description="Options: 'mask_email', 'redact_all', 'hash_pii', 'keep'")

class Observation(BaseModel):
    visible_data: List[Dict[str, Any]]
    schema_info: Dict[str, str]
    current_step: int
    max_steps: int

class Reward(BaseModel):
    value: float
    description: str

# --- Environment Core ---

class DataShieldEnv:
    def __init__(self):
        self.max_steps = 20
        self.reset()

    def reset(self, task_data: pd.DataFrame = None) -> Observation:
        if task_data is None:
            # Default fallback data
            task_data = pd.DataFrame({"text": ["Contact: john@doe.com", "ID: 444-00-1111"]})
        
        self.df = task_data.copy()
        self.original_df = task_data.copy()
        self.current_step = 0
        self.done = False
        return self.state()

    def state(self) -> Observation:
        return Observation(
            visible_data=self.df.to_dict(orient="records"),
            schema_info={col: str(dtype) for col, dtype in self.df.dtypes.items()},
            current_step=self.current_step,
            max_steps=self.max_steps
        )

    def step(self, action: Action):
        self.current_step += 1
        
        # 1. Apply Transformation
        target_val = str(self.df.at[action.row_index, action.column_name])
        
        if action.transformation == "mask_email":
            new_val = re.sub(r"[\w\.-]+@[\w\.-]+", "####@####.com", target_val)
        elif action.transformation == "redact_all":
            new_val = "[REDACTED]"
        elif action.transformation == "hash_pii":
            new_val = str(hash(target_val))[:10]
        else:
            new_val = target_val
            
        self.df.at[action.row_index, action.column_name] = new_val

        # 2. Reward Shaping
        # Reward for changing PII, penalty for over-redacting non-PII
        reward_val = self._calculate_reward(action, target_val, new_val)
        
        if self.current_step >= self.max_steps:
            self.done = True

        return self.state(), Reward(value=reward_val, description="Step completed"), self.done, {}

    def _calculate_reward(self, action, old_val, new_val) -> float:
        # Simple heuristic: If it looked like an email/SSN and changed, +0.5
        # If it was clean text and was redacted, -0.5 (Utility loss)
        pii_patterns = [r"[\w\.-]+@[\w\.-]+", r"\d{3}-\d{2}-\d{4}"]
        is_pii = any(re.search(p, str(old_val)) for p in pii_patterns)
        
        if is_pii and old_val != new_val:
            return 0.5
        if not is_pii and old_val != new_val:
            return -0.3
        return 0.0
